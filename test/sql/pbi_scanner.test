# name: test/sql/pbi_scanner.test
# description: test pbi_scanner extension bootstrap
# group: [sql]

query I
SELECT count(*)
FROM duckdb_functions()
WHERE function_name = 'dax_query';
----
0

require pbi_scanner

query I
SELECT count(*)
FROM duckdb_functions()
WHERE function_name = 'dax_query';
----
1

query I
SELECT __pbi_scanner_test_parse_chunked_double(
    '<?xml version="1.0" encoding="utf-8"?><root><schema xmlns:xsd="http://www.w3.org/2001/XMLSchema"><xsd:schema><xsd:complexType name="row"><xsd:sequence><xsd:element name="Rate" type="xsd:double" /></xsd:sequence></xsd:complexType></xsd:schema></schema><row><Rate>1.125E2</Ra',
    'te></row></root>'
);
----
112.5

query I
SELECT __pbi_scanner_test_parse_binxml_double(
    ''
);
----
112.5

query I
SELECT __pbi_scanner_test_parse_binxml_double(
    'dfff01b004f00472006f006f007400ef000001f801f00372006f007700ef000002f802f0045200610074006500ef000003f803040000000000205c40f7f7f7'
);
----
112.5

query I
SELECT length(__pbi_scanner_test_parse_binxml_first_text(
    'dfff01b004f00472006f006f007400ef000001f801f00372006f007700ef000002f802f0045200610074006500ef000003f80386f7f7f7'
));
----
4

query I
SELECT CAST(__pbi_scanner_test_metadata_cache_roundtrip() AS INTEGER);
----
1

query T
SELECT __pbi_scanner_test_service_principal_error_message('request_error');
----
service principal token request failed: simulated_request_error

query T
SELECT __pbi_scanner_test_service_principal_error_message('http_error');
----
service principal token request http 401: denied

query T
SELECT __pbi_scanner_test_service_principal_error_message('invalid_json');
----
service principal token response was not valid JSON

query T
SELECT __pbi_scanner_test_service_principal_error_message('missing_access_token');
----
service principal token response did not include access_token

query T
SELECT __pbi_scanner_test_coerce_xml_type('1899-12-30T12:34:56', 'TIMESTAMP');
----
TIMESTAMP

query T
SELECT __pbi_scanner_test_coerce_xml_type('1899-12-30T12:34:56+00:00', 'TIMESTAMP_TZ');
----
TIMESTAMP WITH TIME ZONE

query T
SELECT __pbi_scanner_test_coerce_xml_type('1899-12-30T12:34:56', 'TIME');
----
TIME

query I
SELECT length(__pbi_scanner_test_coerce_xml_text('', 'VARCHAR'));
----
0

query T
SELECT __pbi_scanner_test_coerce_xml_text('', 'INFER');
----
<NULL>

query T
SELECT __pbi_scanner_test_coerce_xml_text('1', 'DATE');
----
1899-12-31

query T
SELECT __pbi_scanner_test_coerce_xml_text('0.5', 'TIME');
----
12:00:00

query T
SELECT __pbi_scanner_test_coerce_xml_text('2.5', 'TIMESTAMP');
----
1900-01-01 12:00:00

query T
SELECT __pbi_scanner_test_coerce_xml_type('9223372036854775807', 'BIGINT');
----
BIGINT

query T
SELECT __pbi_scanner_test_coerce_xml_type('1234.5678', 'DOUBLE');
----
DOUBLE

query T
SELECT __pbi_scanner_test_coerce_xml_type('true', 'BOOLEAN');
----
BOOLEAN

query T
SELECT __pbi_scanner_test_coerce_xml_text('0', 'DATE');
----
1899-12-30

query T
SELECT __pbi_scanner_test_coerce_xml_text('-1', 'DATE');
----
1899-12-29

query T
SELECT __pbi_scanner_test_coerce_xml_text('0.9999999', 'TIME');
----
23:59:59.99136

query T
SELECT __pbi_scanner_test_coerce_xml_text('45292.25', 'TIMESTAMP');
----
2024-01-01 06:00:00

query T
SELECT __pbi_scanner_test_effective_execution_transport(
    'EVALUATE INFO.VIEW.TABLES()'
);
----
sx_xpress

statement error
SELECT *
FROM dax_query(
    'Initial Catalog=example_semantic_model;',
    'EVALUATE ROW("x", 1)'
);
----
Data Source is required

statement error
SELECT *
FROM dax_query(
    'Data Source=powerbi://api.powerbi.com/v1.0/myorg/Example%20Workspace;Initial Catalog=example_semantic_model;',
    'EVALUATE ROW("x", 1)',
    secret_name := ''
);
----
secret_name must not be empty

statement error
SELECT *
FROM dax_query(
    'Data Source=powerbi://api.powerbi.com/v1.0/myorg/Example%20Workspace;Initial Catalog=example_semantic_model;Secret=one;',
    'EVALUATE ROW("x", 1)',
    secret_name := 'two'
);
----
secret_name named parameter conflicts with Secret in the connection string

statement error
SELECT *
FROM dax_query(
    'Data Source=powerbi://api.powerbi.com/v1.0/myorg/Example%20Workspace;Initial Catalog=example_semantic_model;',
    'EVALUATE ROW("x", 1)'
);
----
access_token named parameter or PBI_XMLA_ACCESS_TOKEN environment variable is required

statement ok
SET pbi_scanner_auth_mode='azure_cli';

statement error
SELECT *
FROM dax_query(
    'Data Source=powerbi://api.powerbi.com/v1.0/myorg/Example%20Workspace;Initial Catalog=example_semantic_model;',
    'EVALUATE ROW("x", 1)',
    auth_mode := 'unsupported_mode'
);
----
unsupported auth_mode "unsupported_mode"

statement ok
SET pbi_scanner_auth_mode='';

statement error
SET pbi_scanner_auth_mode='unsupported_mode';
----
unsupported auth_mode "unsupported_mode"

statement error
SELECT *
FROM dax_query(
    'Data Source=https://example.com/xmla?vs=sobe_wowvirtualserver&db=example_db;Initial Catalog=sobe_wowvirtualserver-example_db;',
    'EVALUATE ROW("x", 1)'
);
----
access_token named parameter or PBI_XMLA_ACCESS_TOKEN environment variable is required
