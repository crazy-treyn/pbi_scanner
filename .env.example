# Copy to .env (or export in your shell) for local benchmarking.
# Do not commit .env — it is gitignored.

# Required for real runs against your workspace (fictional placeholders ship in the script)
PBI_BENCH_CONNECTION_STRING=Data Source=powerbi://api.powerbi.com/v1.0/myorg/Example%20Workspace;Initial Catalog=example_semantic_model;
PBI_BENCH_DAX=EVALUATE ROW("x", 1)

# Optional: DuckDB secret name for Azure auth (see README)
PBI_BENCH_SECRET_NAME=pbi_cli

# Optional harness toggles (see README / AGENTS.md)
# PBI_BENCH_MODE=materialize
# PBI_BENCH_ITERATIONS=1
# PBI_BENCH_DIRECT_XMLA=0
# PBI_SCANNER_XMLA_TRANSPORT=sx_xpress
# PBI_SCANNER_DISABLE_METADATA_CACHE=0
